<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Interactive Notes & Lists</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ---------- RESET & BASE ---------- */
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: #0b0b0b;
            /* deep black */
            color: #f5e56b;
            /* warm yellow */
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ---------- SCROLLBAR ---------- */
        ::-webkit-scrollbar {
            width: 5px;
        }
        ::-webkit-scrollbar-track {
            background: #1a1a1a;
        }
        ::-webkit-scrollbar-thumb {
            background: #f5e56b;
            border-radius: 12px;
        }
        

        /* ---------- SIDEBAR ---------- */
        .sidebar {
            position: relative;
            width: 280px;
            min-width: 280px;
            background: #141414;
            border-right: 1px solid #3a3a2a;
            height: 100vh;
            overflow-y: auto;
            padding: 1.8rem 0.8rem 2rem 1.2rem;
            transition: transform 0.25s ease, margin 0.25s ease, opacity 0.2s ease;
            z-index: 10;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.6);
        }

        /* Capitalize text consistently */
        .section-title span,
        .subsection-list li,
        .content-section h3,
        .note-item .note-content p,
        .list-item .task-text {
            text-transform: capitalize;
        }

        .sidebar.hidden {
            transform: translateX(-100%);
            margin-right: -280px;
            opacity: 0;
            pointer-events: none;
        }

        /* ---------- TOGGLE BUTTON ---------- */
        .sidebar-toggle-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 20;
            padding: 1.2rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: transparent;
            pointer-events: none;
        }

        /* Delete subsection button */
        .delete-sub {
            color: #7a7a5a;
            font-size: 0.65rem;
            cursor: pointer;
            transition: 0.15s;
            margin-left: auto;
        }
        .delete-sub:hover {
            color: #e74c5e;
        }

        .sidebar-toggle-wrapper button {
            pointer-events: auto;
            background: #1a1a1a;
            border: 1px solid #f5e56b;
            border-radius: 40px;
            padding: 0.5rem 1rem;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            color: #f5e56b;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 0 12px rgba(245, 229, 107, 0.15);
        }

        .sidebar-toggle-wrapper button:hover {
            background: #2a2a1a;
            border-color: #ffe066;
            box-shadow: 0 0 20px rgba(245, 229, 107, 0.25);
        }

        .sidebar-content {
            padding-top: 4.5rem;
        }

        /* ---------- SAVE INDICATOR ---------- */
        .save-indicator {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            background: #f5e56b;
            color: #0b0b0b;
            padding: 0.5rem 1rem;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: 30;
            box-shadow: 0 4px 20px rgba(245, 229, 107, 0.3);
            pointer-events: none;
        }

        .save-indicator.show {
            opacity: 1;
        }

        .save-indicator.error {
            background: #e74c5e;
            color: #fff;
            box-shadow: 0 4px 20px rgba(231, 76, 94, 0.3);
        }

        /* ---------- SYNC STATUS ---------- */
        .sync-status {
            font-size: 0.7rem;
            color: #b8a84a;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .sync-status i {
            font-size: 0.6rem;
        }

        .sync-status .synced {
            color: #f5e56b;
        }

        .sync-status .unsynced {
            color: #e74c5e;
        }

        .sync-status .syncing {
            color: #f4a261;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            from {
                transform: rotate(0deg);
            }
            to {
                transform: rotate(360deg);
            }
        }

        /* ---------- STATUS PANEL ---------- */
        .status-panel {
            background: #1a1a12;
            border: 1px solid #3a3a2a;
            border-radius: 12px;
            padding: 0.8rem 1.2rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .status-panel .status-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.8rem;
            color: #d4c45a;
        }

        .status-panel .status-info i {
            color: #f5e56b;
        }

        .status-panel .status-info .connected {
            color: #f5e56b;
        }

        .status-panel .status-info .disconnected {
            color: #7a7a5a;
        }

        .status-panel .status-actions button {
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            border: 1px solid #3a3a2a;
            background: #1a1a12;
            font-size: 0.7rem;
            cursor: pointer;
            transition: 0.15s;
            color: #d4c45a;
        }

        .status-panel .status-actions button:hover {
            background: #2a2a1a;
            border-color: #f5e56b;
        }

        /* ---------- SIDEBAR SECTIONS ---------- */
        .section-group {
            margin-bottom: 1.8rem;
        }

        .section-title {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            color: #d4c45a;
            padding: 0.5rem 0.4rem 0.3rem 0.4rem;
            border-bottom: 1px solid #2a2a1a;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: default;
        }

        .section-title .section-actions i {
            margin-left: 6px;
            color: #7a7a5a;
            font-size: 0.7rem;
            cursor: pointer;
            transition: 0.15s;
        }

        .section-title .section-actions i:hover {
            color: #f5e56b;
        }

        .subsection-list {
            list-style: none;
            margin-top: 0.25rem;
        }

        .subsection-list li {
            padding: 0.35rem 0.4rem 0.35rem 1.2rem;
            font-size: 0.9rem;
            color: #d4c45a;
            border-radius: 6px;
            margin: 0.1rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: default;
        }

        .subsection-list li i {
            color: #7a7a5a;
            font-size: 0.75rem;
            width: 1.1rem;
        }

        .subsection-list li:hover {
            background: #1a1a12;
        }

        /* ---------- ADD SECTION BUTTON ---------- */
        .add-section-btn {
            background: transparent;
            border: none;
            color: #b8a84a;
            font-size: 0.8rem;
            padding: 0.3rem 0.2rem;
            margin-top: 2.5rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: 0.15s;
            border-radius: 20px;
            padding: 0.3rem 0.8rem;
        }

        .add-section-btn:hover {
            background: #1a1a12;
            color: #f5e56b;
        }

        /* ---------- MAIN CONTENT ---------- */
        .main {
            flex: 1;
            height: 100vh;
            overflow-y: auto;
            padding: 2rem 2.5rem 3rem 2.5rem;
            background: #0b0b0b;
            transition: padding 0.2s;
            margin-left: 0;
        }

        .main-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2.5rem;
            padding-top: 0.5rem;
            padding-bottom: 0.8rem;
            border-bottom: 2px solid #2a2a1a;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .main-header h1 {
            font-size: 2rem;
            font-weight: 600;
            color: #f5e56b;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .main-header h1 i {
            color: #f5e56b;
        }

        .main-header .badge {
            background: #1a1a12;
            padding: 0.3rem 1.2rem;
            border-radius: 40px;
            font-size: 0.8rem;
            color: #d4c45a;
            border: 1px solid #2a2a1a;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* ---------- CONTENT SECTIONS ---------- */
        .content-section {
            background: #141414;
            border-radius: 18px;
            padding: 1.8rem 2rem 2rem 2rem;
            margin-bottom: 2.5rem;
            border: 1px solid #2a2a1a;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        }

        .content-section h3 {
            font-size: 1.4rem;
            font-weight: 600;
            color: #f5e56b;
            margin-bottom: 1.4rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding-bottom: 0.6rem;
            border-bottom: 1px solid #2a2a1a;
        }

        .content-section h3 i {
            color: #f5e56b;
            font-size: 1.2rem;
        }

        .content-section h3 .section-tools {
            margin-left: auto;
            font-size: 0.7rem;
            font-weight: 400;
            color: #7a7a5a;
            display: flex;
            gap: 8px;
        }

        .content-section h3 .section-tools i {
            cursor: pointer;
            color: #7a7a5a;
            font-size: 0.8rem;
            transition: 0.15s;
        }

        .content-section h3 .section-tools i:hover {
            color: #e74c5e;
        }

        /* ---------- NOTES ---------- */
        .note-item {
            background: #1a1a12;
            border-left: 4px solid #f5e56b;
            padding: 0.9rem 1.2rem;
            border-radius: 10px;
            margin-bottom: 0.8rem;
            display: flex;
            align-items: flex-start;
            gap: 0.8rem;
        }

        .note-item i {
            color: #f5e56b;
            margin-top: 0.2rem;
            font-size: 0.9rem;
        }

        .note-item .note-content {
            flex: 1;
        }

        .note-item .note-content p {
            color: #e8d86a;
            line-height: 1.5;
        }

        .note-item .note-tools {
            font-size: 0.7rem;
            color: #7a7a5a;
            display: flex;
            gap: 8px;
            margin-top: 4px;
        }

        .note-item .note-tools i {
            cursor: pointer;
            color: #7a7a5a;
            font-size: 0.7rem;
        }

        .note-item .note-tools i:hover {
            color: #e74c5e;
        }

        /* ---------- LIST ITEMS ---------- */
        .list-container {
            margin: 0.8rem 0 0.2rem 0;
        }

        .list-item {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            padding: 0.4rem 0.2rem;
            border-bottom: 1px solid #1a1a12;
            color: #d4c45a;
        }

        .list-item i {
            color: #7a7a5a;
            width: 1.2rem;
            font-size: 0.8rem;
            cursor: pointer;
        }

        .list-item i:hover {
            color: #f5e56b;
        }

        .list-item .task-text {
            flex: 1;
        }

        .list-item .tag {
            background: #1a1a12;
            padding: 0.05rem 0.7rem;
            border-radius: 20px;
            font-size: 0.65rem;
            color: #b8a84a;
            border: 1px solid #2a2a1a;
        }

        .list-item .list-tools i {
            color: #7a7a5a;
            font-size: 0.7rem;
            margin-left: 4px;
            cursor: pointer;
        }

        .list-item .list-tools i:hover {
            color: #e74c5e;
        }

        /* ---------- EMPTY STATE ---------- */
        .empty-message {
            color: #7a7a5a;
            padding: 1.2rem 0.2rem;
            font-style: italic;
            font-size: 0.95rem;
        }

        .empty-state-hero {
            text-align: center;
            padding: 4rem 2rem;
            background: #141414;
            border-radius: 18px;
            border: 1px solid #2a2a1a;
        }

        .empty-state-hero i {
            font-size: 3rem;
            color: #3a3a2a;
            margin-bottom: 1.2rem;
        }

        .empty-state-hero p {
            color: #b8a84a;
            font-size: 1.1rem;
        }

        /* ---------- ACTION BUTTONS ---------- */
        .section-actions-main {
            display: flex;
            gap: 10px;
            margin-top: 16px;
            flex-wrap: wrap;
            padding-top: 12px;
            border-top: 1px solid #1a1a12;
        }

        .action-btn {
            background: #1a1a12;
            border: 1px solid #2a2a1a;
            padding: 0.25rem 1rem;
            border-radius: 40px;
            font-size: 0.75rem;
            color: #d4c45a;
            cursor: pointer;
            transition: 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .action-btn:hover {
            background: #2a2a1a;
            border-color: #f5e56b;
            color: #f5e56b;
        }
        /* For clickable sections in sidebar */
        .section-title {
            cursor: pointer;
            transition: 0.15s;
        }
        .section-title:hover {
            color: #f5e56b;
            background: #1a1a12;
            border-radius: 4px;
        }
        .section-title.active {
            color: #f5e56b;
            border-left: 3px solid #f5e56b;
            padding-left: 0.8rem;
        }

        /* For clickable subsections */
        .subsection-list li {
            cursor: pointer;
            transition: 0.15s;
        }
        .subsection-list li:hover {
            background: #1a1a12;
            color: #f5e56b;
        }
        .subsection-list li.active {
            background: #2a2a1a;
            color: #f5e56b;
            border-left: 3px solid #f5e56b;
        }

        /* Hide all content sections by default */
        .content-section {
            display: none;
        }
        .content-section.visible {
            display: block;
        }

        .empty-state-hero .action-btn {
            margin-top: 1.5rem;
            font-size: 0.9rem;
            padding: 0.5rem 2rem;
        }

        /* ---------- RESPONSIVE ---------- */
        @media (max-width: 700px) {
            .sidebar {
                width: 240px;
                min-width: 240px;
            }
            .sidebar.hidden {
                transform: translateX(-100%);
                margin-right: -240px;
            }
            .main {
                padding: 1.5rem 1.2rem;
            }
            .main-header h1 {
                font-size: 1.5rem;
            }
            .sidebar-toggle-wrapper {
                padding: 0.8rem 1rem;
            }
            .sidebar-content {
                padding-top: 4rem;
            }
        }

        @media (max-width: 480px) {
            .sidebar {
                width: 200px;
                min-width: 200px;
            }
            .sidebar.hidden {
                margin-right: -200px;
            }
            .sidebar-content {
                padding-top: 3.8rem;
            }
        }
    </style>
</head>
<body>

    <!-- TOGGLE BUTTON -->
    <div class="sidebar-toggle-wrapper">
        <button id="toggleSidebarBtn"><i class="fas fa-bars"></i> <span>Notes</span></button>
    </div>

    <!-- SAVE INDICATOR -->
    <div class="save-indicator" id="saveIndicator">
        <i class="fas fa-check-circle"></i> Saved
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-content">
            <div class="status-panel" id="statusPanel">
                <div class="status-info">
                    <i class="fas fa-cloud"></i>
                    <span id="statusText">Cloud sync: <span class="disconnected">not configured</span></span>
                </div>
                <div class="status-actions">
                    <button onclick="syncNow()" id="syncBtn"><i class="fas fa-sync"></i> Sync</button>
                </div>
            </div>
            <div id="sidebarSectionsContainer"></div>
            <button class="add-section-btn" id="addSectionBtn"><i class="fas fa-plus-circle"></i> Add section</button>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main" id="mainContent">
        <div class="main-header">
            <h1><i class="fas fa-sticky-note"></i> Notes & Lists</h1>
            <span class="badge" id="syncStatus">
                <i class="fas fa-database"></i>
                <span id="syncLabel">local</span>
            </span>
        </div>
        <div id="mainSectionsContainer"></div>
    </main>

    <script>
        // ============================================================
        //  CONFIGURATION – Set your Vercel API URL here
        // ============================================================
        const VERCEL_API_URL = 'https://notes-7e9f690p1-drakenotes1.vercel.app/api/notes';

        // ============================================================
        //  DATA STATE
        // ============================================================
        let sections = [];
        let nextId = 1;
        let isSyncing = false;
        let saveTimeout = null;
        let isVercelConfigured = false;
        let selectedSectionId = null;
        let selectedSubsection = null;

        const STORAGE_KEY = 'notesAppData';

        // DOM refs
        const sidebarContainer = document.getElementById('sidebarSectionsContainer');
        const mainContainer = document.getElementById('mainSectionsContainer');
        const addSectionBtn = document.getElementById('addSectionBtn');
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const syncLabel = document.getElementById('syncLabel');
        const statusText = document.getElementById('statusText');
        const syncBtn = document.getElementById('syncBtn');
        let sidebarVisible = true;

        // ============================================================
        //  VERCELL API FUNCTIONS
        // ============================================================

        async function loadFromVercel() {
            try {
                const response = await fetch(VERCEL_API_URL);
                if (!response.ok) {
                    if (response.status === 404) {
                        return null;
                    }
                    throw new Error(`HTTP ${response.status}`);
                }
                const data = await response.json();
                return data;
            } catch (error) {
                console.error('Error loading from Vercel:', error);
                showSaveIndicator('Failed to load from cloud', true);
                return null;
            }
        }

        async function saveToVercel(data) {
            try {
                const response = await fetch(VERCEL_API_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                if (!response.ok) {
                    const error = await response.json();
                    throw new Error(error.error || `HTTP ${response.status}`);
                }

                showSaveIndicator('Saved to cloud!');
                updateSyncStatus('synced');
                return true;
            } catch (error) {
                console.error('Error saving to Vercel:', error);
                showSaveIndicator(`Save failed: ${error.message}`, true);
                updateSyncStatus('unsynced');
                return false;
            }
        }

        // ============================================================
        //  SYNC FUNCTIONS
        // ============================================================

        async function syncFromVercel() {
            if (isSyncing) return;
            isSyncing = true;
            updateSyncStatus('syncing');
            syncBtn.disabled = true;
            syncBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Syncing';

            try {
                const data = await loadFromVercel();
                if (data && data.sections) {
                    sections = data.sections || [];
                    nextId = data.nextId || 1;
                    render();
                    showSaveIndicator('Loaded from cloud!');
                    updateStatusPanel(true);
                } else {
                    await saveToVercel({ sections, nextId });
                    updateStatusPanel(true);
                }
            } catch (error) {
                console.error('Sync failed:', error);
                showSaveIndicator('Sync failed', true);
            } finally {
                isSyncing = false;
                updateSyncStatus('synced');
                syncBtn.disabled = false;
                syncBtn.innerHTML = '<i class="fas fa-sync"></i> Sync';
            }
        }

        window.syncNow = async function() {
            if (!isVercelConfigured) {
                showSaveIndicator('Vercel API not configured. Check the URL.', true);
                return;
            }
            await syncFromVercel();
        };

        // ============================================================
        //  UI HELPERS
        // ============================================================

        function updateSyncStatus(status) {
            const statusMap = {
                'synced': '<i class="fas fa-check-circle synced"></i> synced',
                'unsynced': '<i class="fas fa-exclamation-circle unsynced"></i> unsynced',
                'syncing': '<i class="fas fa-spinner syncing"></i> syncing...',
                'local': '<i class="fas fa-database"></i> local'
            };
            syncLabel.innerHTML = statusMap[status] || statusMap.local;
        }

        function updateStatusPanel(connected) {
            if (connected) {
                statusText.innerHTML = `Cloud sync: <span class="connected">connected</span>`;
                isVercelConfigured = true;
            } else {
                statusText.innerHTML = `Cloud sync: <span class="disconnected">not configured</span>`;
                isVercelConfigured = false;
            }
        }

        function showSaveIndicator(message, isError = false) {
            const indicator = document.getElementById('saveIndicator');
            indicator.textContent = message;
            indicator.className = 'save-indicator show';
            if (isError) indicator.classList.add('error');

            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(() => {
                indicator.classList.remove('show');
                indicator.classList.remove('error');
            }, 3000);
        }

        function esc(str) {
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }
        // Capitalize first letter of each word
        function capitalize(str) {
            if (!str) return '';
            return str.split(' ').map(word => 
                word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
            ).join(' ');
        }

        function genId() { return nextId++; }

        // ============================================================
        //  LOCAL STORAGE (fallback)
        // ============================================================

        function loadLocalData() {
            try {
                const saved = localStorage.getItem(STORAGE_KEY);
                if (saved) {
                    const parsed = JSON.parse(saved);
                    sections = parsed.sections || [];
                    nextId = parsed.nextId || 1;
                }
            } catch (e) {
                console.warn('Failed to load local data', e);
            }
        }

        function saveLocalData() {
            try {
                const data = { sections, nextId };
                localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
            } catch (e) {
                console.warn('Failed to save local data', e);
            }
        }

        // ============================================================
        //  RENDER FUNCTIONS
        // ============================================================

        function render() {
            renderSidebar();
            renderMain();
            saveLocalData();

            if (isVercelConfigured && !isSyncing) {
                clearTimeout(saveTimeout);
                saveTimeout = setTimeout(() => {
                    saveToVercel({ sections, nextId });
                }, 1000);
            }
        }

        function renderSidebar() {
            if (!sidebarContainer) return;
            if (sections.length === 0) {
                sidebarContainer.innerHTML = '';
                return;
            }
            let html = '';
            sections.forEach((sec) => {
                const isActive = selectedSectionId === sec.id && !selectedSubsection;
                const isSubActive = selectedSectionId === sec.id && selectedSubsection;
                html += `<div class="section-group" data-section-id="${sec.id}">`;
                html += `<div class="section-title ${isActive ? 'active' : ''}" onclick="selectSection(${sec.id})" title="Click to view this section">
                            <span><i class="fas fa-folder-open" style="margin-right:6px;"></i> ${capitalize(sec.name)}</span>
                            <span class="section-actions">
                                <i class="fas fa-trash-alt" onclick="event.stopPropagation(); deleteSection(${sec.id})" title="delete section"></i>
                                <i class="fas fa-plus-circle" onclick="event.stopPropagation(); addSubsection(${sec.id})" title="add subsection"></i>
                            </span>
                        </div>`;
                html += `<ul class="subsection-list">`;
                if (sec.subs && sec.subs.length > 0) {
                    sec.subs.forEach(sub => {
                        const isSubActive2 = isSubActive && sub.name === selectedSubsection;
                        html += `<li class="${isSubActive2 ? 'active' : ''}" onclick="selectSubsection(${sec.id}, '${sub.name}')">
                                    <i class="fas fa-circle"></i> ${capitalize(sub.name)}
                                    <span class="delete-sub" onclick="event.stopPropagation(); deleteSubsection(${sec.id}, '${sub.name}')" title="delete subsection">
                                        <i class="fas fa-times"></i>
                                    </span>
                                </li>`;
                    });
                } else {
                    html += `<li style="color:#7a7a5a; font-size:0.8rem; padding-left:1.2rem; cursor:default;"><i class="fas fa-ellipsis-h"></i> no subs</li>`;
                }
                html += `</ul>`;
                html += `</div>`;
            });
            sidebarContainer.innerHTML = html;
        }

        function renderMain() {
            if (!mainContainer) return;
            if (sections.length === 0) {
                mainContainer.innerHTML = `
                            <div class="empty-state-hero">
                                <i class="fas fa-pencil-alt"></i>
                                <p>Start by adding a section<br><span style="font-size:0.9rem; color:#7a7a5a;">use the sidebar or the button below</span></p>
                                <button class="action-btn" onclick="addSectionFromMain()" style="margin-top:1.5rem; font-size:0.9rem; padding:0.5rem 2rem;"><i class="fas fa-plus-circle"></i> Add section</button>
                            </div>
                        `;
                return;
            }

            if (selectedSectionId === null && selectedSubsection === null) {
                mainContainer.innerHTML = `
                            <div class="empty-state-hero">
                                <i class="fas fa-folder-open"></i>
                                <p>Select a section from the sidebar<br><span style="font-size:0.9rem; color:#7a7a5a;">click on a section title or subsection to view its content</span></p>
                            </div>
                        `;
                return;
            }

            const selectedSec = sections.find(s => s.id === selectedSectionId);
            if (!selectedSec) {
                mainContainer.innerHTML = `
                            <div class="empty-state-hero">
                                <i class="fas fa-exclamation-triangle"></i>
                                <p>Section not found</p>
                            </div>
                        `;
                return;
            }

            let html = '';
            const sec = selectedSec;
            html += `<div class="content-section visible" data-section-id="${sec.id}">`;
            
            // If a subsection is selected, show its content
            if (selectedSubsection) {
                const sub = sec.subs.find(s => s.name === selectedSubsection);
                if (!sub) {
                    html += `<div class="empty-state-hero">
                                <i class="fas fa-exclamation-triangle"></i>
                                <p>Subsection not found</p>
                            </div>`;
                    html += `</div>`;
                    mainContainer.innerHTML = html;
                    return;
                }
                
                html += `<h3>
                            <i class="fas fa-folder-open"></i> ${capitalize(sec.name)} <span style="font-size:0.9rem; color:#7a7a5a; font-weight:400;"> / ${capitalize(sub.name)}</span>
                            <span class="section-tools">
                                <i class="fas fa-arrow-left" onclick="clearSelection()" title="back to sections"></i>
                                <i class="fas fa-trash-alt" onclick="deleteSection(${sec.id})" title="delete section"></i>
                            </span>
                        </h3>`;

                // Show notes in this subsection
                if (sub.notes && sub.notes.length > 0) {
                    sub.notes.forEach((note, ni) => {
                        html += `<div class="note-item">
                            <i class="fas fa-pen-fancy"></i>
                            <div class="note-content">
                                <p>${esc(note)}</p>
                                <div class="note-tools">
                                    <i class="fas fa-edit" onclick="editSubNote(${sec.id}, '${sub.name}', ${ni})" title="edit note"></i>
                                    <i class="fas fa-trash-alt" onclick="deleteSubNote(${sec.id}, '${sub.name}', ${ni})" title="delete note"></i>
                                </div>
                            </div>
                        </div>`;
                    });
                } else {
                    html += `<div class="empty-message"><i class="far fa-sticky-note"></i> No notes in this subsection</div>`;
                }

                // Show list items in this subsection
                if (sub.listItems && sub.listItems.length > 0) {
                    html += `<div class="list-container">`;
                    sub.listItems.forEach((item, liIdx) => {
                        const icon = item.done ? 'fa-check-circle' : 'fa-circle';
                        const color = item.done ? '#f5e56b' : '#7a7a5a';
                        html += `<div class="list-item">
                            <i class="fas ${icon}" style="color:${color};" onclick="toggleSubListItem(${sec.id}, '${sub.name}', ${liIdx})" title="toggle done"></i>
                            <span class="task-text">${esc(item.text)}</span>
                            <span class="tag">${item.done ? 'done' : 'pending'}</span>
                            <span class="list-tools">
                                <i class="fas fa-edit" onclick="editSubListItem(${sec.id}, '${sub.name}', ${liIdx})" title="edit item"></i>
                                <i class="fas fa-trash-alt" onclick="deleteSubListItem(${sec.id}, '${sub.name}', ${liIdx})" title="delete item"></i>
                            </span>
                        </div>`;
                    });
                    html += `</div>`;
                } else {
                    html += `<div class="empty-message"><i class="fas fa-list-ul"></i> No list items in this subsection</div>`;
                }

                html += `<div class="section-actions-main">
                            <button class="action-btn" onclick="addSubNote(${sec.id}, '${sub.name}')"><i class="fas fa-plus"></i> Add note</button>
                            <button class="action-btn" onclick="addSubListItem(${sec.id}, '${sub.name}')"><i class="fas fa-plus"></i> Add list item</button>
                            <button class="action-btn" onclick="addSubsection(${sec.id})"><i class="fas fa-plus"></i> Add subsection</button>
                        </div>`;

            } else {
                // Show parent section (shows section notes, lists, and subsections)
                html += `<h3>
                            <i class="fas fa-folder-open"></i> ${capitalize(sec.name)}
                            <span class="section-tools">
                                <i class="fas fa-arrow-left" onclick="clearSelection()" title="back to sections"></i>
                                <i class="fas fa-trash-alt" onclick="deleteSection(${sec.id})" title="delete section"></i>
                            </span>
                        </h3>`;

                // Show notes in this section
                if (sec.notes && sec.notes.length > 0) {
                    sec.notes.forEach((note, ni) => {
                        html += `<div class="note-item">
                            <i class="fas fa-pen-fancy"></i>
                            <div class="note-content">
                                <p>${esc(note)}</p>
                                <div class="note-tools">
                                    <i class="fas fa-edit" onclick="editNote(${sec.id}, ${ni})" title="edit note"></i>
                                    <i class="fas fa-trash-alt" onclick="deleteNote(${sec.id}, ${ni})" title="delete note"></i>
                                </div>
                            </div>
                        </div>`;
                    });
                } else {
                    html += `<div class="empty-message"><i class="far fa-sticky-note"></i> No notes in this section</div>`;
                }

                // Show list items in this section
                if (sec.listItems && sec.listItems.length > 0) {
                    html += `<div class="list-container">`;
                    sec.listItems.forEach((item, liIdx) => {
                        const icon = item.done ? 'fa-check-circle' : 'fa-circle';
                        const color = item.done ? '#f5e56b' : '#7a7a5a';
                        html += `<div class="list-item">
                            <i class="fas ${icon}" style="color:${color};" onclick="toggleListItem(${sec.id}, ${liIdx})" title="toggle done"></i>
                            <span class="task-text">${esc(item.text)}</span>
                            <span class="tag">${item.done ? 'done' : 'pending'}</span>
                            <span class="list-tools">
                                <i class="fas fa-edit" onclick="editListItem(${sec.id}, ${liIdx})" title="edit item"></i>
                                <i class="fas fa-trash-alt" onclick="deleteListItem(${sec.id}, ${liIdx})" title="delete item"></i>
                            </span>
                        </div>`;
                    });
                    html += `</div>`;
                } else {
                    html += `<div class="empty-message"><i class="fas fa-list-ul"></i> No list items in this section</div>`;
                }

                // Show subsections as a list
                if (sec.subs && sec.subs.length > 0) {
                    html += `<div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #2a2a1a;">
                                <div style="color: #7a7a5a; font-size: 0.8rem; margin-bottom: 0.5rem;"><i class="fas fa-sitemap"></i> Subsections</div>`;
                    sec.subs.forEach(sub => {
                        html += `<div style="padding: 0.3rem 0.5rem; border-bottom: 1px solid #1a1a12; color: #d4c45a; display: flex; justify-content: space-between; align-items: center;">
                                    <span><i class="fas fa-circle" style="font-size:0.6rem; color:#7a7a5a;"></i> ${capitalize(sub.name)}</span>
                                    <span style="font-size:0.7rem; color:#7a7a5a;">
                                        ${sub.notes ? sub.notes.length : 0} notes · ${sub.listItems ? sub.listItems.length : 0} items
                                    </span>
                                </div>`;
                    });
                    html += `</div>`;
                }

                html += `<div class="section-actions-main">
                            <button class="action-btn" onclick="addNote(${sec.id})"><i class="fas fa-plus"></i> Add note</button>
                            <button class="action-btn" onclick="addListItem(${sec.id})"><i class="fas fa-plus"></i> Add list item</button>
                            <button class="action-btn" onclick="addSubsection(${sec.id})"><i class="fas fa-plus"></i> Add subsection</button>
                        </div>`;
            }

            html += `</div>`;
            mainContainer.innerHTML = html;
        }

        // ============================================================
        //  SELECTION FUNCTIONS
        // ============================================================

        function selectSection(sectionId) {
            selectedSectionId = sectionId;
            selectedSubsection = null;
            render();
        }

        function selectSubsection(sectionId, subsectionName) {
            selectedSectionId = sectionId;
            selectedSubsection = subsectionName.toLowerCase();
            render();
        }

        function clearSelection() {
            selectedSectionId = null;
            selectedSubsection = null;
            render();
        }

        // ============================================================
        //  CRUD OPERATIONS
        // ============================================================

        window.addSectionFromMain = function() {
            const name = prompt('Section name:');
            if (name && name.trim()) {
                sections.push({ id: genId(), name: name.trim(), subs: [], notes: [], listItems: [] });
                render();
            }
        };

        window.addSectionFromSidebar = function() {
            const name = prompt('Section name:');
            if (name && name.trim()) {
                sections.push({ id: genId(), name: name.trim(), subs: [], notes: [], listItems: [] });
                render();
            }
        };

        window.deleteSection = function(id) {
            if (!confirm('Delete this section and all its content?')) return;
            sections = sections.filter(s => s.id !== id);
            if (selectedSectionId === id) {
                selectedSectionId = null;
                selectedSubsection = null;
            }
            render();
        };

        window.addSubsection = function(id) {
            const sec = sections.find(s => s.id === id);
            if (!sec) return;
            const sub = prompt('Subsection name:');
            if (sub && sub.trim()) {
                if (!sec.subs) sec.subs = [];
                sec.subs.push({ name: sub.trim(), notes: [], listItems: [] });
                render();
            }
        };

        window.addNote = function(id) {
            const sec = sections.find(s => s.id === id);
            if (!sec) return;
            const note = prompt('Note text:');
            if (note && note.trim()) {
                sec.notes.push(note.trim());
                render();
            }
        };

        window.deleteNote = function(id, noteIndex) {
            const sec = sections.find(s => s.id === id);
            if (!sec) return;
            if (!confirm('Delete this note?')) return;
            sec.notes.splice(noteIndex, 1);
            render();
        };

        window.addListItem = function(id) {
            const sec = sections.find(s => s.id === id);
            if (!sec) return;
            const text = prompt('List item text:');
            if (text && text.trim()) {
                sec.listItems.push({ text: text.trim(), done: false });
                render();
            }
        };

        window.deleteListItem = function(id, idx) {
            const sec = sections.find(s => s.id === id);
            if (!sec) return;
            if (!confirm('Delete this list item?')) return;
            sec.listItems.splice(idx, 1);
            render();
        };

        window.toggleListItem = function(id, idx) {
            const sec = sections.find(s => s.id === id);
            if (!sec) return;
            sec.listItems[idx].done = !sec.listItems[idx].done;
            render();
        };

        // ============================================================
        //  EDIT FUNCTIONS - SECTION NOTES & LIST ITEMS
        // ============================================================

        // Edit note in section
        window.editNote = function(sectionId, noteIndex) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const currentText = sec.notes[noteIndex];
            if (!currentText) return;
            const newText = prompt('Edit note:', currentText);
            if (newText !== null && newText.trim() !== '') {
                sec.notes[noteIndex] = newText.trim();
                render();
            }
        };

        // Edit list item in section
        window.editListItem = function(sectionId, itemIndex) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const currentText = sec.listItems[itemIndex].text;
            if (!currentText) return;
            const newText = prompt('Edit list item:', currentText);
            if (newText !== null && newText.trim() !== '') {
                sec.listItems[itemIndex].text = newText.trim();
                render();
            }
        };

        // ============================================================
        //  EDIT FUNCTIONS - SUBSECTION NOTES & LIST ITEMS
        // ============================================================

        // Edit note in subsection
        window.editSubNote = function(sectionId, subName, noteIndex) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const sub = sec.subs.find(s => s.name === subName);
            if (!sub) return;
            const currentText = sub.notes[noteIndex];
            if (!currentText) return;
            const newText = prompt('Edit note:', currentText);
            if (newText !== null && newText.trim() !== '') {
                sub.notes[noteIndex] = newText.trim();
                render();
            }
        };

        // Edit list item in subsection
        window.editSubListItem = function(sectionId, subName, itemIndex) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const sub = sec.subs.find(s => s.name === subName);
            if (!sub) return;
            const currentText = sub.listItems[itemIndex].text;
            if (!currentText) return;
            const newText = prompt('Edit list item:', currentText);
            if (newText !== null && newText.trim() !== '') {
                sub.listItems[itemIndex].text = newText.trim();
                render();
            }
        };
        // ============================================================
        //  SUBSECTION CRUD OPERATIONS
        // ============================================================

        window.deleteSubsection = function(sectionId, subName) {
            if (!confirm(`Delete subsection "${capitalize(subName)}" and all its content?`)) return;
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const index = sec.subs.findIndex(s => s.name === subName);
            if (index !== -1) {
                sec.subs.splice(index, 1);
                if (selectedSectionId === sectionId && selectedSubsection === subName) {
                    selectedSubsection = null;
                }
                render();
            }
        };

        // Add note to subsection
        window.addSubNote = function(sectionId, subName) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const sub = sec.subs.find(s => s.name === subName);
            if (!sub) return;
            const note = prompt('Note text:');
            if (note && note.trim()) {
                if (!sub.notes) sub.notes = [];
                sub.notes.push(note.trim());
                render();
            }
        };

        // Add list item to subsection
        window.addSubListItem = function(sectionId, subName) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const sub = sec.subs.find(s => s.name === subName);
            if (!sub) return;
            const text = prompt('List item text:');
            if (text && text.trim()) {
                if (!sub.listItems) sub.listItems = [];
                sub.listItems.push({ text: text.trim(), done: false });
                render();
            }
        };

        // Delete note from subsection
        window.deleteSubNote = function(sectionId, subName, noteIndex) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const sub = sec.subs.find(s => s.name === subName);
            if (!sub) return;
            if (!confirm('Delete this note?')) return;
            sub.notes.splice(noteIndex, 1);
            render();
        };

        // Delete list item from subsection
        window.deleteSubListItem = function(sectionId, subName, itemIndex) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const sub = sec.subs.find(s => s.name === subName);
            if (!sub) return;
            if (!confirm('Delete this list item?')) return;
            sub.listItems.splice(itemIndex, 1);
            render();
        };

        // Toggle list item in subsection
        window.toggleSubListItem = function(sectionId, subName, itemIndex) {
            const sec = sections.find(s => s.id === sectionId);
            if (!sec) return;
            const sub = sec.subs.find(s => s.name === subName);
            if (!sub) return;
            sub.listItems[itemIndex].done = !sub.listItems[itemIndex].done;
            render();
        };

        // ============================================================
        //  INITIALIZATION
        // ============================================================

        if (VERCEL_API_URL && VERCEL_API_URL !== 'https://your-vercel-app.vercel.app/api/notes') {
            updateStatusPanel(true);
            isVercelConfigured = true;
        } else {
            updateStatusPanel(false);
            isVercelConfigured = false;
        }

        loadLocalData();
        render();

        if (isVercelConfigured) {
            setTimeout(() => {
                syncFromVercel();
            }, 500);
        }

        toggleBtn.addEventListener('click', function() {
            sidebarVisible = !sidebarVisible;
            sidebar.classList.toggle('hidden', !sidebarVisible);
            toggleBtn.innerHTML = sidebarVisible ? '<i class="fas fa-bars"></i> <span>Notes</span>' :
                '<i class="fas fa-chevron-right"></i> <span>Notes</span>';
        });

        addSectionBtn.addEventListener('click', window.addSectionFromSidebar);
    </script>
</body>
</html>